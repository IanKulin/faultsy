<%- include('partials/header', { title: 'Faultsy' }) %>
<div class="top-bar">
  <h1>Faultsy</h1>
  <a href="/whitelist">Whitelist</a>
  <form class="inline" method="POST" action="/logout">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <button class="logout" type="submit">Logout</button>
  </form>
</div>
<% if (sites.length === 0) { %>
  <p class="empty">No monitored sites yet.</p>
<% } else { %>
  <table>
    <thead>
      <tr><th>Site</th><th>Errors (48h)</th><th>Last Error</th><th>Last Access</th><th>Hits</th></tr>
    </thead>
    <tbody>
      <% for (const s of sites) { %>
        <tr>
          <td><a href="/site/<%= encodeURIComponent(s.hostname) %>"><%= s.hostname %></a></td>
          <td><%= s.error_count %></td>
          <td>
            <% if (s.last_error_message) { %>
              <%= s.last_error_message.length > 80 ? s.last_error_message.slice(0, 80) + '…' : s.last_error_message %>
              <br><small><%- formatTs(s.last_error_ts) %></small>
            <% } %>
          </td>
          <td><%- formatTs(s.last_seen) %></td>
          <td><%= s.snippet_hits %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>
<%- include('partials/footer') %>
